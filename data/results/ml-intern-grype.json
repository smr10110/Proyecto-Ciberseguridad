core":2.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-39378","epss":0.00035,"percentile":0.10316,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-39378","cwe":"CWE-22","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-39378","cwe":"CWE-73","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["7.17.1"],"state":"fixed","available":[{"version":"7.17.1","date":"2026-04-22","kind":"first-observed"}]},"advisories":[],"risk":0.020124999999999997},"relatedVulnerabilities":[{"id":"CVE-2026-39378","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-39378","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/jupyter/nbconvert/releases/tag/v7.17.1","https://github.com/jupyter/nbconvert/security/advisories/GHSA-7jqv-fw35-gmx9"],"description":"The nbconvert tool, jupyter nbconvert, converts Jupyter notebooks to various other formats via Jinja templates. In versions 6.5 through 7.17.0, when `HTMLExporter.embed_images=True`, nbconvert's markdown renderer allows arbitrary file read via path traversal in image references. A malicious notebook can exfiltrate sensitive files from the conversion host by embedding them as base64 data URIs in the output HTML. nbconvert 7.17.1 contains a fix. As a workaround, do not enable `HTMLExporter.embed_images`; it is not enabled by default.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:H/I:N/A:N","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-39378","epss":0.00035,"percentile":0.10316,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-39378","cwe":"CWE-22","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-39378","cwe":"CWE-73","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"lang