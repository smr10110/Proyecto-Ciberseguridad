378611dd6fb2532b189a9087877d8f0c0489","https://github.com/authlib/authlib/commit/7974f45e4d7492ab5f527577677f2770ce423228"],"description":"Authlib has 1-click Account Takeover vulnerability","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:L/UI:R/S:U/C:H/I:N/A:N","metrics":{"baseScore":5.7,"exploitabilityScore":2.1,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-68158","epss":0.00025,"percentile":0.06993,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-68158","cwe":"CWE-352","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["1.6.6"],"state":"fixed","available":[{"version":"1.6.6","date":"2026-01-10","kind":"first-observed"}]},"advisories":[],"risk":0.013375},"relatedVulnerabilities":[{"id":"CVE-2025-68158","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-68158","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/authlib/authlib/commit/2808378611dd6fb2532b189a9087877d8f0c0489","https://github.com/authlib/authlib/commit/7974f45e4d7492ab5f527577677f2770ce423228","https://github.com/authlib/authlib/security/advisories/GHSA-fg6f-75jq-6523"],"description":"Authlib is a Python library which builds OAuth and OpenID Connect servers. In versions 1.0.0 through 1.6.5, cache-backed state/request-token storage is not tied to the initiating user session, so CSRF is possible for any attacker that has a valid state (easily obtainable via an attacker-initiated authentication flow). When a cache is supplied to the OAuth client registry, FrameworkIntegration.set_state_data writes the entire state blob under _state_{app}_{state}, and get_state_data ignores the caller’s session altogether. This issue has been patched in version 1.6.6.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:H","metrics":{"baseScore":8.8,"exploitabilityScore":2.9,"impactScore":5.9},"vendorMetadata":{}},{"source":"security-advisories@github.com","t