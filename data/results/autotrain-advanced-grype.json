.gov/vuln/detail/CVE-2026-33231","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/nltk/nltk/commit/bbaae83db86a0f49e00f5b0db44a7254c268de9b","https://github.com/nltk/nltk/security/advisories/GHSA-jm6w-m3j8-898g"],"description":"NLTK (Natural Language Toolkit) is a suite of open source Python modules, data sets, and tutorials supporting research and development in Natural Language Processing. In versions 3.9.3 and prior, `nltk.app.wordnet_app` allows unauthenticated remote shutdown of the local WordNet Browser HTTP server when it is started in its default mode. A simple `GET /SHUTDOWN%20THE%20SERVER` request causes the process to terminate immediately via `os._exit(0)`, resulting in a denial of service. Commit bbaae83db86a0f49e00f5b0db44a7254c268de9b patches the issue.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-33231","epss":0.00019,"percentile":0.05209,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-33231","cwe":"CWE-306","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"nltk","version":"3.9.1"}},"found":{"vulnerabilityID":"GHSA-jm6w-m3j8-898g","versionConstraint":"<=3.9.3 (python)"},"fix":{"suggestedVersion":"3.9.4"}}],"artifact":{"id":"f15bf5ac396aa2dc","name":"nltk","version":"3.9.1","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-nltk:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python-nltk:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python_nltk:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python_nltk:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:nltk:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:nltk:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python-nltk:nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python_nltk:nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python:nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:nltk:nltk:3.9.1:*:*:*:*:*:*:*"],"purl":"pkg:pypi/nltk@3.9.1","upstreams":[]}},{"vulnerability":{"id":"GHSA-fg6f-75jq-6523","dataSource":"https://github.com/advisories/GHSA-fg6f-75jq-6523","namespace":"github:language:python","severity":"Medium","urls":["https://github.com/authlib/authlib/security/advisories/GHSA-fg6f-75jq-6523","https://nvd.nist.gov/vuln/detail/CVE-2025-68158","https://github.com/authlib/authlib/commit/2808378611dd6fb2532b189a9087877d8f0c0489","https://github.com/authlib/authlib/commit/7974f45e4d7492ab5f527577677f2770ce423228"],"description":"Authlib has 1-click Account Takeover vulnerability","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:L/UI:R/S:U/C:H/I:N/A:N","metrics":{"baseScore":5.7,"exploitabilityScore":2.1,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-68158","epss":0.00025,"percentile":0.06993,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-68158","cwe":"CWE-352","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["1.6.6"],"state":"fixed","available":[{"version":"1.6.6","date":"2026-01-10","kind":"first-observed"}]},"advisories":[],"risk":0.013375},"relatedVulnerabilities":[{"id":"CVE-2025-68158","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-68158","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/authlib/authlib/commit/2808378611dd6fb2532b189a9087877d8f0c0489","https://github.com/authlib/authlib/commit/7974f45e4d7492ab5f527577677f2770ce423228","https://github.com/authlib/authlib/security/advisories/GHSA-fg6f-75jq-6523"],"description":"Authlib is a Python library which builds OAuth and OpenID Connect servers. In versions 1.0.0 through 1.6.5, cache-backed state/request-token storage is not tied to the initiating user session, so CSRF is possible for any attacker that has a valid state (easily obtainable via an attacker-initiated authentication flow). When a cache is supplied to the OAuth client registry, FrameworkIntegration.set_state_data writes the entire state blob under _state_{app}_{state}, and get_state_data ignores the caller’s session altogether. This issue has been patched in version 1.6.6.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:H","metrics":{"baseScore":8.8,"exploitabilityScore":2.9,"impactScore":5.9},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:L/UI:R/S:U/C:H/I:N/A:N","metrics":{"baseScore":5.7,"exploitabilityScore":2.1,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-68158","epss":0.00025,"percentile":0.06993,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-68158","cwe":"CWE-352","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"authlib","version":"1.4.0"}},"found":{"vulnerabilityID":"GHSA-fg6f-75jq-6523","versionConstraint":">=1.0.0,<=1.6.5 (python)"},"fix":{"suggestedVersion":"1.6.6"}}],"artifact":{"id":"55ed6bcdb3e5b44e","name":"authlib","version":"1.4.0","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python-authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2