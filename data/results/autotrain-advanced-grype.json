formers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python-transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:transformers:4.48.0:*:*:*:*:*:*:*"],"purl":"pkg:pypi/transformers@4.48.0","upstreams":[]}},{"vulnerability":{"id":"GHSA-fpwr-67px-3qhx","dataSource":"https://github.com/advisories/GHSA-fpwr-67px-3qhx","namespace":"github:language:python","severity":"Medium","urls":["https://nvd.nist.gov/vuln/detail/CVE-2025-1194","https://github.com/huggingface/transformers/commit/92c5ca9dd70de3ade2af2eb835c96215cc50e815","https://huntr.com/bounties/86f58dcd-683f-4adc-a735-849f51e9abb2"],"description":"Transformers Regular Expression Denial of Service (ReDoS) vulnerability","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:L","metrics":{"baseScore":4.3,"exploitabilityScore":2.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-1194","epss":0.00078,"percentile":0.22901,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-1194","cwe":"CWE-1333","source":"security@huntr.dev","type":"Secondary"}],"fix":{"versions":["4.50.0"],"state":"fixed","available":[{"version":"4.50.0","date":"2025-04-30","kind":"first-observed"}]},"advisories":[],"risk":0.03627},"relatedVulnerabilities":[{"id":"CVE-2025-1194","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-1194","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/huggingface/transformers/commit/92c5ca9dd70de3ade2af2eb835c96215cc50e815","https://huntr.com/bounties/86f58dcd-683f-4adc-a735-849f51e9abb2"],"description":"A Regular Expression Denial of Service (ReDoS) vulnerability was identified in the huggingface/transformers library, specifically in the file `tokenization_gpt_neox_japanese.py` of the GPT-NeoX-Japanese model. The vulnerability occurs in the SubWordJapaneseTokenizer class, where regular expressions process specially crafted inputs. The issue stems from a regex exhibiting exponential complexity under certain conditions, leading to excessive backtracking. This can result in high CPU usage and potential application downtime, effectively creating a Denial of Service (DoS) scenario. The affected version is v4.48.1 (latest).","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:H","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"security@huntr.dev","type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:L","metrics":{"baseScore":4.3,"exploitabilityScore":2.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-1194","epss":0.00078,"percentile":0.22901,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-1194","cwe":"CWE-1333","source":"security@huntr.dev","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"transformers","version":"4.48.0"}},"found":{"vulnerabilityID":"GHSA-fpwr-67px-3qhx","versionConstraint":"<4.50.0 (python)"},"fix":{"suggestedVersion":"4.50.0"}}],"artifact":{"id":"597062d805f321b6","name":"transformers","version":"4.48.0","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python-transformers