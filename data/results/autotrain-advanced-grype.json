e authz bypass)","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:H/A:N","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-59420","epss":0.0001,"percentile":0.01117,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-59420","cwe":"CWE-345","source":"security-advisories@github.com","type":"Secondary"},{"cve":"CVE-2025-59420","cwe":"CWE-863","source":"security-advisories@github.com","type":"Secondary"},{"cve":"CVE-2025-59420","cwe":"CWE-345","source":"nvd@nist.gov","type":"Primary"}],"fix":{"versions":["1.6.4"],"state":"fixed","available":[{"version":"1.6.4","date":"2025-09-23","kind":"first-observed"}]},"advisories":[],"risk":0.007500000000000001},"relatedVulnerabilities":[{"id":"CVE-2025-59420","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-59420","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/authlib/authlib/commit/6b1813e4392eb7c168c276099ff7783b176479df","https://github.com/authlib/authlib/security/advisories/GHSA-9ggr-2464-2j32","https://lists.debian.org/debian-lts-announce/2025/10/msg00032.html"],"description":"Authlib is a Python library which builds OAuth and OpenID Connect servers. Prior to version 1.6.4, Authlib’s JWS verification accepts tokens that declare unknown critical header parameters (crit), violating RFC 7515 “must‑understand” semantics. An attacker can craft a signed token with a critical header (for example, bork or cnf) that strict verifiers reject but Authlib accepts. In mixed‑language fleets, this enables split‑brain verification and can lead to policy bypass, replay, or privilege escalation. This issue has been patched in version 1.6.4.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:H/A:N","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-59420","epss