trics":{"baseScore":3.5,"exploitabilityScore":2.1,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-3777","epss":0.00055,"percentile":0.17012,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-3777","cwe":"CWE-20","source":"security@huntr.dev","type":"Secondary"}],"fix":{"versions":["4.52.1"],"state":"fixed","available":[{"version":"4.52.1","date":"2025-07-09","kind":"first-observed"}]},"advisories":[],"risk":0.017875},"relatedVulnerabilities":[{"id":"CVE-2025-3777","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-3777","namespace":"nvd:cpe","severity":"Low","urls":["https://github.com/huggingface/transformers/commit/4dda5f71b35fb70cf602187eef84bb17a50b9082","https://huntr.com/bounties/ccba0730-9248-4853-b7ff-5c20e6364f09"],"description":"Hugging Face Transformers versions up to 4.49.0 are affected by an improper input validation vulnerability in the `image_utils.py` file. The vulnerability arises from insecure URL validation using the `startswith()` method, which can be bypassed through URL username injection. This allows attackers to craft URLs that appear to be from YouTube but resolve to malicious domains, potentially leading to phishing attacks, malware distribution, or data exfiltration. The issue is fixed in version 4.52.1.","cvss":[{"source":"security@huntr.dev","type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:N/AC:L/PR:L/UI:R/S:U/C:L/I:N/A:N","metrics":{"baseScore":3.5,"exploitabilityScore":2.1,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-3777","epss":0.00055,"percentile":0.17012,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-3777","cwe":"CWE-20","source":"security@huntr.dev","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"transformers","version":"4.48.0"}},"found":{"vulnerabilityID":"GHSA-phhr-52qp-3mj4","versionConstraint":"<4.52.1 (python)"},"fix":{"suggestedVersion":"4.52