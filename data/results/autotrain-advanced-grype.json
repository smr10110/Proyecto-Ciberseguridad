ers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python-transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:transformers:4.48.0:*:*:*:*:*:*:*"],"purl":"pkg:pypi/transformers@4.48.0","upstreams":[]}},{"vulnerability":{"id":"GHSA-q2wp-rjmx-x6x9","dataSource":"https://github.com/advisories/GHSA-q2wp-rjmx-x6x9","namespace":"github:language:python","severity":"Medium","urls":["https://nvd.nist.gov/vuln/detail/CVE-2025-3263","https://github.com/huggingface/transformers/commit/0720e206c6ba28887e4d60ef60a6a089f6c1cc76","https://huntr.com/bounties/c7a69150-54f8-4e81-8094-791e7a2a0f29","https://github.com/huggingface/transformers/commit/126abe3461762e5fc180e7e614391d1b4ab051ca"],"description":"Transformers's ReDoS vulnerability in get_configuration_file can lead to catastrophic backtracking","cvss":[{"type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-3263","epss":0.00096,"percentile":0.26206,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-3263","cwe":"CWE-1333","source":"security@huntr.dev","type":"Secondary"}],"fix":{"versions":["4.51.0"],"state":"fixed","available":[{"version":"4.51.0","date":"2025-07-09","kind":"first-observed"}]},"advisories":[],"risk":0.04944},"relatedVulnerabilities":[{"id":"CVE-2025-3263","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-3263","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/huggingface/transformers/commit/0720