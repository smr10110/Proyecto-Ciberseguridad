tadata":{}}],"epss":[{"cve":"CVE-2025-66221","epss":0.00028,"percentile":0.08005,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-66221","cwe":"CWE-67","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["3.1.4"],"state":"fixed","available":[{"version":"3.1.4","date":"2025-12-02","kind":"first-observed"}]},"advisories":[],"risk":0.015819999999999997},"relatedVulnerabilities":[{"id":"CVE-2025-66221","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-66221","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/pallets/werkzeug/commit/4b833376a45c323a189cd11d2362bcffdb1c0c13","https://github.com/pallets/werkzeug/releases/tag/3.1.4","https://github.com/pallets/werkzeug/security/advisories/GHSA-hgf8-39gv-g3f2"],"description":"Werkzeug is a comprehensive WSGI web application library. Prior to version 3.1.4, Werkzeug's safe_join function allows path segments with Windows device names. On Windows, there are special device names such as CON, AUX, etc that are implicitly present and readable in every directory. send_from_directory uses safe_join to safely serve files at user-specified paths under a directory. If the application is running on Windows, and the requested path ends with a special device name, the file will be opened successfully, but reading will hang indefinitely. This issue has been patched in version 3.1.4.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:P/PR:N/UI:N/VC:N/VI:N/VA:L/SC:N/SI:N/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":6.3},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-66221","epss":0.00028,"percentile":0.08005,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-66221","cwe":"CWE-67","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"werkzeug","version":"3.1.3"}},"found":{"vulnerabilityID":"GHSA-hgf8-39gv-g3f2","versionConstraint":"<3.1.4 (python)"},"fix":{"suggestedVersion":"3.1.4"}}],"artifact":{"id":"3c6894b2b1cd66a1","name":"werkzeug","version":"3.1.3","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-werkzeug:python-werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python-werkzeug:python_werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python_werkzeug:python-werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python_werkzeug:python_werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python-werkzeug:werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python_werkzeug:werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:werkzeug:python-werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:werkzeug:python_werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python:python-werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python:python_werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:werkzeug:werkzeug:3.1.3:*:*:*:*:*:*:*","cpe:2.3:a:python:werkzeug:3.1.3:*:*:*:*:*:*:*"],"purl":"pkg:pypi/werkzeug@3.1.3","upstreams":[]}},{"vulnerability":{"id":"GHSA-469j-vmhf-r6v7","dataSource":"https://github.com/advisories/GHSA-469j-vmhf-r6v7","namespace":"github:language:python","severity":"High","urls":["https://github.com/nltk/nltk/security/advisories/GHSA-469j-vmhf-r6v7","https://nvd.nist.gov/vuln/detail/CVE-2026-33236","https://github.com/nltk/nltk/commit/89fe2ec2c6bae6e2e7a46dad65cc34231976ed8a"],"description":"NLTK has a Downloader Path Traversal Vulnerability (AFO) - Arbitrary File Overwrite","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:H/A:H","metrics":{"baseScore":8.1,"exploitabilityScore":2.9,"impactScore":5.2},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-33236","epss":0.00019,"percentile":0.05322,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-33236","cwe":"CWE-22","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":[],"state":"not-fixed"},"advisories":[],"risk":0.014820000000000003},"relatedVulnerabilities":[{"id":"CVE-2026-33236","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-33236","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/nltk/nltk/commit/89fe2ec2c6bae6e2e7a46dad65cc34231976ed8a","https://github.com/nltk/nltk/security/advisories/GHSA-469j-vmhf-r6v7"],"description":"NLTK (Natural Language Toolkit) is a suite of open source Python modules, data sets, and tutorials supporting research and development in Natural Language Processing. In versions 3.9.3 and prior, the NLTK downloader does not validate the `subdir` and `id` attributes when processing remote XML index files. Attackers can control a remote XML index server to provide malicious values containing path traversal sequences (such as `../`), which can lead to arbitrary directory creation, arbitrary file creation, and arbitrary file overwrite. Commit 89fe2ec2c6bae6e2e7a46dad65cc34231976ed8a patches the issue.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:H/A:H","metrics":{"baseScore":8.1,"exploitabilityScore":2.9,"impactScore":5.2},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-33236","epss":0.00019,"percentile":0.05322,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-33236","cwe":"CWE-22","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"nltk","version":"3.9.1"}},"found":{"vulnerabilityID":"GHSA-469j-vmhf-r6v7","versionConstraint":"<