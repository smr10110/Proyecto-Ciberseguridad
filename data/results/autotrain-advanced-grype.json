may leak .netrc credentials to third parties for specific maliciously-crafted URLs. Users should upgrade to version 2.32.4 to receive a fix. For older versions of Requests, use of the .netrc file can be disabled with `trust_env=False` on one's Requests Session.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:R/S:U/C:H/I:N/A:N","metrics":{"baseScore":5.3,"exploitabilityScore":1.7,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2024-47081","epss":0.00208,"percentile":0.42945,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2024-47081","cwe":"CWE-522","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"requests","version":"2.32.3"}},"found":{"vulnerabilityID":"GHSA-9hjg-9r4m-mvj7","versionConstraint":"<2.32.4 (python)"},"fix":{"suggestedVersion":"2.32.4"}}],"artifact":{"id":"7ae587b350fcb071","name":"requests","version":"2.32.3","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python:requests:2.32.3:*:*:*:*:*:*:*"],"purl":"pkg:pypi/requests@2.32.3","upstreams":[]}},{"vulnerability":{"id":"GHSA-g7f3-828f-7h7m","dataSource":"https://github.com/advisories/GHSA-g7f3-828f-7h7m","namespace":"github:language:python","severity":"Medium","urls":["https://github.com/authlib/authlib/security/advisories/GHSA-g7f3-828f-7h7m","https://github.com/authlib/authlib/commit/e0863d5129316b1790eee5f14cece32a03b8184d","https://nvd.nist.gov/vuln/detail/CVE-2025-62706","https://lists.debian.org/debian-lts-announce/2025/10/msg00032.html"],"description":"Authlib : JWE zip=DEF decompression bomb enables DoS","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:L/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-62706","epss":0.00133,"percentile":0.32418,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-62706","cwe":"CWE-400","source":"security-advisories@github.com","type":"Secondary"},{"cve":"CVE-2025-62706","cwe":"CWE-770","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["1.6.5"],"state":"fixed","available":[{"version":"1.6.5","date":"2025-10-11","kind":"first-observed"}]},"advisories":[],"risk":0.07647499999999999},"relatedVulnerabilities":[{"id":"CVE-2025-62706","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-62706","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/authlib/authlib/commit/e0863d5129316b1790eee5f14cece32a03b8184d","https://github.com/authlib/authlib/security/advisories/GHSA-g7f3-828f-7h7m","https://lists.debian.org/debian-lts-announce/2025/10/msg00032.html"],"description":"Authlib is a Python library which builds OAuth and OpenID Connect servers. Prior to version 1.6.5, Authlib’s JWE zip=DEF path performs unbounded DEFLATE decompression. A very small ciphertext can expand into tens or hundreds of megabytes on decrypt, allowing an attacker who can supply decryptable tokens to exhaust memory and CPU and cause denial of service. This issue has been patched in version 1.6.5. Workarounds for this issue involve rejecting or stripping zip=DEF for inbound JWEs at the application boundary, forking and add a bounded decompression guard via decompressobj().decompress(data, MAX_SIZE)) and returning an error when output exceeds a safe limit, or enforcing strict maximum token sizes and fail fast on oversized inputs; combine with rate limiting.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:L/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-62706","epss":0.00133,"percentile":0.32418,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-62706","cwe":"CWE-400","source":"security-advisories@github.com","type":"Secondary"},{"cve":"CVE-2025-62706","cwe":"CWE-770","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"authlib","version":"1.4.0"}},"found":{"vulnerabilityID":"GHSA-g7f3-828f-7h7m","versionConstraint":"<1.6.5 (python)"},"fix":{"suggestedVersion":"1.6.5"}}],"artifact":{"id":"55ed6bcdb3e5b44e","name":"authlib","version":"1.4.0","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python-authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python-authlib:authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:authlib:authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python:authlib:1.4.0:*:*:*:*:*:*:*"],"purl":"pkg:pypi/authlib@1.4.0","upstreams":[]}},{"vulnerability":{"id":"GHSA-h8wq-7xc4-p3qx","dataSource":"https://github.com/advisories/GHSA-h8wq-7xc4-p3qx","namespace":"github:language:python","severity":"High","urls":["https://nvd.nist.gov/vuln/detail/CVE-2026-0846","https://huntr.com/bounties/007b84f8-418e-4300-99d0-bf504c2f97eb","https://github.com/nltk/nltk/pull/3485","https://github.com/nltk/nltk/commit/b2e1164bf89277f79b65406c829b99fb20ca1974"],"description":"NLTK has Arbitrary File Read via Absolute Path Input in nltk.util.filestring()","cvss":[{"type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:L/A:L","metrics":{"baseScore":8.6,"exploitabilityScore":3.9,"impactScore":4.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-0846","epss":0.00084,"percentile":0.24124,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-0846","cwe":"CWE-36","source":"security@huntr.dev","type":"Secondary"}],"fix":{"versions":["3.9.3"],"state":"fixed","available":[{"version":"3.9.3","date":"2026-04-18","kind":"first-observed"}]},"advisories":[],"risk":0.06762},"relatedVulnerabilities":[{"id":"CVE-2026-0846","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-0846","namespace":"nvd:cpe","severity":"High","urls":["https://huntr.com/bounties/007b84f8-418e-4300-99d0-bf504c2f97eb"],"description":"A vulnerability in the `filestring()` function of the `nltk.util` module in nltk version 3.9.2 allows arbitrary file read due to improper validation of input paths. The function directly opens files specified by user input without sanitization, enabling attackers to access sensitive system files by providing absolute paths or traversal paths. This vulnerability can be exploited locally or remotely, particularly in scenarios where the function is used in web APIs or other interfaces that accept user-supplied input.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"security@huntr.dev","type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:L/A:L","metrics":{"baseScore":8.6,"exploitabilityScore":3.9,"impactScore":4.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-0846","epss":0.00084,"percentile":0.24124,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-0846","cwe":"CWE-36","source":"security@huntr.dev","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"nltk","version":"3.9.1"}},"found":{"vulnerabilityID":"GHSA-h8wq-7xc4-p3qx","versionConstraint":"<3.9.3 (python)"},"fix":{"suggestedVersion":"3.9.3"}}],"artifact":{"id":"f15bf5ac396aa2dc","name":"nltk","version":"3.9.1","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-nltk:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python-nltk:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python_nltk:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python_nltk:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:nltk:python-nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:nltk:python_nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python-nltk:nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python_nltk:nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:python:nltk:3.9.1:*:*:*:*:*:*:*","cpe:2.3:a:nltk:nltk:3.9.1:*:*:*:*:*:*:*"],"purl":"pkg:pypi/nltk@3.9.1","upstreams":[]}},{"vulnerability":{"id":"GHSA-wvwj-cvrp-7pv5","dataSource":"https://github.com/advisories/GHSA-wvwj-cvrp-7pv5","namespace":"github:language:python","severity":"Critical","urls":["https://github.com/authlib/authlib/security/advisories/GHSA-wvwj-cvrp-7pv5","https://github.com/authlib/authlib/commit/a5d4b2d4c9e46bfa11c82f85fdc2bcc0b50ae681","https://github.com/authlib/authlib/releases/tag/v1.6.9","https://nvd.nist.gov/vuln/detail/CVE-2026-27962"],"description":"Authlib JWS JWK Header Injection: Signature Verification Bypass","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N","metrics":{"baseScore":9.1,"exploitabilityScore":3.9,"impactScore":5.2},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27962","epss":0.00074,"percentile":0.22016,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-27962","cwe":"CWE-347","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["1.6.9"],"state":"fixed","available":[{"version":"1.6.9","date":"2026-03-16","kind":"first-observed"}]},"advisories":[],"risk":0.06697},"relatedVulnerabilities":[{"id":"CVE-2026-27962","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-27962","namespace":"nvd:cpe","severity":"Critical","urls":["https://github.com/authlib/authlib/commit/a5d4b2d4c9e46bfa11c82f85fdc2bcc0b50ae681","https://github.com/authlib/authlib/releases/tag/v1.6.9","https://github.com/authlib/authlib/security/advisories/GHSA-wvwj-cvrp-7pv5"],"description":"Authlib is a Python library which builds OAuth and OpenID Connect servers. Prior to version 1.6.9, a JWK Header Injection vulnerability in authlib's JWS implementation allows an unauthenticated attacker to forge arbitrary JWT tokens that pass signature verification. When key=None is passed to any JWS deserialization function, the library extracts and uses the cryptographic key embedded in the attacker-controlled JWT jwk header field. An attacker can sign a token with their own private key, embed the matching public key in the header, and have the server accept the forged token as cryptographically valid — bypassing authentication and authorization entirely. This issue has been patched in version 1.6.9.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N","metrics":{"baseScore":9.1,"exploitabilityScore":3.9,"impactScore":5.2},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27962","epss":0.00074,"percentile":0.22016,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-27962","cwe":"CWE-347","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"authlib","version":"1.4.0"}},