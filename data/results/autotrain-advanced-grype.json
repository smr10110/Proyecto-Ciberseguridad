://huntr.com/bounties/86f58dcd-683f-4adc-a735-849f51e9abb2"],"description":"A Regular Expression Denial of Service (ReDoS) vulnerability was identified in the huggingface/transformers library, specifically in the file `tokenization_gpt_neox_japanese.py` of the GPT-NeoX-Japanese model. The vulnerability occurs in the SubWordJapaneseTokenizer class, where regular expressions process specially crafted inputs. The issue stems from a regex exhibiting exponential complexity under certain conditions, leading to excessive backtracking. This can result in high CPU usage and potential application downtime, effectively creating a Denial of Service (DoS) scenario. The affected version is v4.48.1 (latest).","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:H","metrics":{"baseScore":6.5,"exploitabilityScore":2.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"security@huntr.dev","type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:L","metrics":{"baseScore":4.3,"exploitabilityScore":2.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-1194","epss":0.00078,"percentile":0.22901,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2025-1194","cwe":"CWE-1333","source":"security@huntr.dev","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"transformers","version":"4.48.0"}},"found":{"vulnerabilityID":"GHSA-fpwr-67px-3qhx","versionConstraint":"<4.50.0 (python)"},"fix":{"suggestedVersion":"4.50.0"}}],"artifact":{"id":"597062d805f321b6","name":"transformers","version":"4.48.0","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python-transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python-transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python:transformers:4.48.0:*:*:*:*:*:*:*"],"purl":"pkg:pypi/transformers@4.48.0","upstreams":[]}},{"vulnerability":{"id":"GHSA-m344-f55w-2m6j","dataSource":"https://github.com/advisories/GHSA-m344-f55w-2m6j","namespace":"github:language:python","severity":"High","urls":["https://github.com/authlib/authlib/security/advisories/GHSA-m344-f55w-2m6j","https://github.com/authlib/authlib/commit/b9bb2b25bf8b7e01512d847a95c1749646eaa72b","https://github.com/authlib/authlib/releases/tag/v1.6.9","https://nvd.nist.gov/vuln/detail/CVE-2026-28498"],"description":"Authlib: Fail-Open Cryptographic Verification in OIDC Hash Binding","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:N/UI:N/VC:N/VI:H/VA:N/SC:N/SI:N/SA:N","metrics":{"baseScore":8.2},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-28498","epss":0.00023,"percentile":0.06312,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-28498","cwe":"CWE-354","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-28498","cwe":"CWE-573","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["1.6.9"],"state":"fixed","available":[{"version":"1.6.9","date":"2026-03-16","kind":"first-observed"}]},"advisories":[],"risk":0.018054999999999998},"relatedVulnerabilities":[{"id":"CVE-2026-28498","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-28498","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/authlib/authlib/commit/b9bb2b25bf8b7e01512d847a95c1749646eaa72b","https://github.com/authlib/authlib/releases/tag/v1.6.9","https://github.com/authlib/authlib/security/advisories/GHSA-m344-f55w-2m6j"],"description":"Authlib is a Python library which builds OAuth and OpenID Connect servers. Prior to version 1.6.9, a library-level vulnerability was identified in the Authlib Python library concerning the validation of OpenID Connect (OIDC) ID Tokens. Specifically, the internal hash verification logic (_verify_hash) responsible for validating the at_hash (Access Token Hash) and c_hash (Authorization Code Hash) claims exhibits a fail-open behavior when encountering an unsupported or unknown cryptographic algorithm. This flaw allows an attacker to bypass mandatory integrity protections by supplying a forged ID Token with a deliberately unrecognized alg header parameter. The library intercepts the unsupported state and silently returns True (validation passed), inherently violating fundamental cryptographic design principles and direct OIDC specifications. This issue has been patched in version 1.6.9.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:H/A:N","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:N/UI:N/VC:N/VI:H/VA:N/SC:N/SI:N/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":8.2},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-28498","epss":0.00023,"percentile":0.06312,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-28498","cwe":"CWE-354","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-28498","cwe":"CWE-573","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"authlib","version":"1.4.0"}},"found":{"vulnerabilityID":"GHSA-m344-f55w-2m6j","versionConstraint":"<=1.6.8 (python)"},"fix":{"suggestedVersion":"1.6.9"}}],"artifact":{"id":"55ed6bcdb3e5b44e","name":"authlib","version":"1.4.0","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python-authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:authlib:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:authlib:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python-authlib:authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python_authlib:authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python-authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python:python_authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:authlib:authlib:1.4.0:*:*:*:*:*:*:*","cpe:2.3:a:python:authlib:1.4.0:*:*:*:*:*:*:*"],"purl":"pkg:pypi/authlib@1.4.0","upstreams":[]}},{"vulnerability":{"id":"GHSA-rcv9-qm8p-9p6j","dataSource":"https://github.com/advisories/GHSA-rcv9-qm8p-9p6j","namespace":"github:language:python","severity":"Medium","urls":["https://nvd.nist.gov/vuln/detail/CVE-2025-6051","https://github.com/huggingface/transformers/commit/ba8eaba9865618253f997784aa565b96206426f0","https://huntr.com/bounties/af929523-7b59-418a-bf55-301830b2ac9d","https://github.com/huggingface/transformers/pull/38844","https://github.com/huggingface/transformers/commit/54a02160eb030da9be18231c77791f2eb3a52216"],"description":"Hugging Face Transformers library has Regular Expression Denial of Service","cvss":[{"type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:N/