low 2.6, as the `safe_globals()` context manager provides no protection in these versions. An attacker can exploit this vulnerability by supplying a malicious checkpoint file, such as `rng_state.pth`, which can execute arbitrary code when loaded. The issue is resolved in version v5.0.0rc3.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:L/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:H","metrics":{"baseScore":7.8,"exploitabilityScore":1.9,"impactScore":5.9},"vendorMetadata":{}},{"source":"security@huntr.dev","type":"Secondary","version":"3.0","vector":"CVSS:3.0/AV:L/AC:H/PR:N/UI:R/S:U/C:H/I:L/A:H","metrics":{"baseScore":6.5,"exploitabilityScore":1.1,"impactScore":5.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-1839","epss":0.00016,"percentile":0.03464,"date":"2026-05-06"}],"cwes":[{"cve":"CVE-2026-1839","cwe":"CWE-502","source":"security@huntr.dev","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"transformers","version":"4.48.0"}},"found":{"vulnerabilityID":"GHSA-69w3-r845-3855","versionConstraint":"<5.0.0rc3 (python)"},"fix":{"suggestedVersion":"5.0.0rc3"}}],"artifact":{"id":"597062d805f321b6","name":"transformers","version":"4.48.0","type":"python","locations":[{"path":"/requirements.txt","accessPath":"/requirements.txt","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:python-transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python-transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:python_transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python-transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:python_transformers:transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformers:python-transformers:4.48.0:*:*:*:*:*:*:*","cpe:2.3:a:transformer